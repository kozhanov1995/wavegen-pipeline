      "id": "63a81155-0ca9-4c87-aa55-48637924af47",
      "name": "🎬 Creatomate — Poll Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        944,
        16
      ]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst status = data.status;\nconst url = data.url;\n\nif (status === 'failed') {\n  throw new Error('Creatomate render failed: ' + (data.error_message || JSON.stringify(data)));\n}\n\nif (status !== 'succeeded' || !url) {\n  throw new Error('Render not ready, status: ' + status + '. Try re-running in 30s.');\n}\n\nconst concept = $('⚙️ Parse Claude JSON').first().json;\n\nreturn [{ json: { \n  ...concept,\n  render_id: data.id,\n  final_video_url: url,\n  render_status: status\n} }];"
      },
      "id": "8b2e7134-c3ce-4f1e-b734-2e327474d489",
      "name": "⚙️ Check Render Done",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
