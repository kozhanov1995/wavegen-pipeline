      "parameters": {
        "jsCode": "const binaryData = $input.first().binary;\nconst jsonData = $input.first().json;\n\n// Переименовываем файл из data.mpga в audio.mp3\nreturn [{\n  json: jsonData,\n  binary: {\n    data: {\n      ...binaryData.data,\n      fileName: 'audio.mp3',\n      fileExtension: 'mp3',\n      mimeType: 'audio/mpeg'\n    }\n  }\n}];"
