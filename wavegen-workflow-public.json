        "jsCode": "const yt = $input.first().json;\nconst videoId = yt.uploadId;  // ← было yt.id\nconst concept = $('⚙️ Merge Video + Metadata').first().json;\nreturn [{ json: {\n  video_id: videoId,\n  youtube_url: 'https://youtube.com/shorts/' + videoId,\n  theme: concept.theme,\n  title: concept.youtube_title\n}}];"
      },
